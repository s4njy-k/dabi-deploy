# Copy to .env and fill in. .env is gitignored.

# GCP / Artifact Registry
PROJECT=dabi-prod-01

# Image SHAs (bumped by CI on every merge to main of each upstream repo)
API_SHA=replace-with-7-char-git-sha
INGEST_SHA=replace-with-7-char-git-sha

# Heap / memory sizing — defaults are TIER 2 BETTER on c4a-standard-16-lssd (64 GB RAM)
# For laptop dev, override to OPENSEARCH_HEAP=2g, CLICKHOUSE_MAX_MEMORY=2147483648
OPENSEARCH_HEAP=30g
CLICKHOUSE_MAX_MEMORY=12884901888    # 12 GiB

# TLS / DNS (Phase 9)
TLS_DOMAIN=dabi.example.com
TLS_EMAIL=ops@example.com
