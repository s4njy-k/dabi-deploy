<clickhouse>
    <storage_configuration>
        <disks>
            <scratch>
                <path>/var/lib/clickhouse-scratch/</path>
            </scratch>
        </disks>
        <policies>
            <scratch>
                <volumes>
                    <main>
                        <disk>scratch</disk>
                    </main>
                </volumes>
            </scratch>
        </policies>
    </storage_configuration>
</clickhouse>
